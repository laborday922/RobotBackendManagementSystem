<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.function.mapper.SysMapMapper">

    <resultMap type="SysMap" id="SysMapResult">
        <id property="mapId" column="map_id"/>
        <result property="mapName" column="map_name"/>
        <result property="mapFile" column="map_file"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
        <!-- 动态计算点位数量 -->
        <result property="pointCountTemp" column="point_count"/>
    </resultMap>

    <sql id="selectMapVo">
        SELECT m.*,
        (SELECT COUNT(*) FROM sys_point p WHERE p.map_id = m.map_id AND p.del_flag = '0') as point_count
        FROM sys_map m
    </sql>

    <select id="selectById" parameterType="Long" resultMap="SysMapResult">
        <include refid="selectMapVo"/>
        WHERE m.map_id = #{mapId} AND m.del_flag = '0'
    </select>

    <select id="selectList" parameterType="SysMap" resultMap="SysMapResult">
        <include refid="selectMapVo"/>
        WHERE m.del_flag = '0'
        <if test="mapName != null and mapName != ''">
            AND m.map_name like concat('%', #{mapName}, '%')
        </if>
        <if test="status != null and status != ''">
            AND m.status = #{status}
        </if>
        ORDER BY m.create_time DESC
    </select>

    <insert id="insert" parameterType="SysMap" useGeneratedKeys="true" keyProperty="mapId">
        INSERT INTO sys_map (
        map_name, map_file, status, del_flag,
        create_by, create_time, remark
        ) VALUES (
        #{mapName}, #{mapFile}, #{status}, '0',
        #{createBy}, #{createTime}, #{remark}
        )
    </insert>

    <update id="update" parameterType="SysMap">
        UPDATE sys_map
        <set>
            <if test="mapName != null and mapName != ''">map_name = #{mapName},</if>
            <if test="mapFile != null and mapFile != ''">map_file = #{mapFile},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        WHERE map_id = #{mapId}
    </update>

    <update id="deleteById" parameterType="Long">
        UPDATE sys_map SET del_flag = '2' WHERE map_id = #{mapId}
    </update>

</mapper>