<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.function.mapper.SysMapMapper">

    <!-- 修复：实体类使用 mapFile，XML 中应该映射为 map_file -->
    <resultMap id="SysMapResult" type="com.ruoyi.function.domain.SysMap">
        <id property="mapId" column="map_id"/>
        <result property="mapName" column="map_name"/>
        <result property="mapFile" column="map_file"/>
        <result property="pointCount" column="point_count"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <!-- 修复：字段名改为 map_file，移除不存在的字段或添加判断 -->
    <sql id="selectMapVo">
        select map_id, map_name, map_file, point_count, status,
        create_time, update_time, create_by, update_by, remark
        from sys_map
    </sql>

    <select id="selectById" parameterType="Long" resultMap="SysMapResult">
        <include refid="selectMapVo"/>
        where map_id = #{mapId}
    </select>

    <select id="selectList" parameterType="com.ruoyi.function.domain.SysMap" resultMap="SysMapResult">
        <include refid="selectMapVo"/>
        <where>
            <if test="mapName != null and mapName != ''">
                and map_name like concat('%', #{mapName}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.function.domain.SysMap" useGeneratedKeys="true" keyProperty="mapId">
        insert into sys_map (
        <if test="mapName != null and mapName != ''">map_name,</if>
        <if test="mapFile != null and mapFile != ''">map_file,</if>
        <if test="pointCount != null">point_count,</if>
        <if test="status != null and status != ''">status,</if>
        <if test="createTime != null">create_time,</if>
        <if test="createBy != null and createBy != ''">create_by,</if>
        <if test="remark != null and remark != ''">remark,</if>
        update_time
        ) values (
        <if test="mapName != null and mapName != ''">#{mapName},</if>
        <if test="mapFile != null and mapFile != ''">#{mapFile},</if>
        <if test="pointCount != null">#{pointCount},</if>
        <if test="status != null and status != ''">#{status},</if>
        <if test="createTime != null">#{createTime},</if>
        <if test="createBy != null and createBy != ''">#{createBy},</if>
        <if test="remark != null and remark != ''">#{remark},</if>
        #{updateTime}
        )
    </insert>

    <update id="update" parameterType="com.ruoyi.function.domain.SysMap">
        update sys_map
        <set>
            <if test="mapName != null and mapName != ''">map_name = #{mapName},</if>
            <if test="mapFile != null and mapFile != ''">map_file = #{mapFile},</if>
            <if test="pointCount != null">point_count = #{pointCount},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null and remark != ''">remark = #{remark},</if>
        </set>
        where map_id = #{mapId}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from sys_map where map_id = #{mapId}
    </delete>

</mapper>