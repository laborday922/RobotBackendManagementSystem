<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mode.mapper.SysModeScheduleMapper">

    <resultMap type="com.ruoyi.mode.domain.SysModeSchedule" id="SysModeScheduleResult">
        <id     property="scheduleId"       column="schedule_id"        />
        <result property="scheduleName"     column="schedule_name"      />
        <result property="modeId"           column="mode_id"            />
        <result property="modeName"         column="mode_name"          />
        <result property="executeTime"      column="execute_time"       />
        <result property="repeatType"       column="repeat_type"        />
        <result property="startDate"        column="start_date"         />
        <result property="startTime"        column="start_time"         />
        <result property="duration"         column="duration"           />
        <result property="status"           column="status"             />
        <result property="lastExecuteTime"  column="last_execute_time"  />
        <result property="lastExecuteStatus" column="last_execute_status" />
        <result property="delFlag"          column="del_flag"           />
        <result property="createBy"         column="create_by"          />
        <result property="createTime"       column="create_time"        />
        <result property="updateBy"         column="update_by"          />
        <result property="updateTime"       column="update_time"        />
        <result property="tenantId"         column="tenant_id"          />
    </resultMap>

    <!-- 机器人结果映射 -->
    <resultMap type="com.ruoyi.mode.domain.SysRobot" id="SysRobotResult">
        <id     property="robotId"          column="id"                 />
        <result property="name"             column="name"               />
        <result property="code"             column="code"               />
        <result property="groupId"          column="group_id"           />
        <result property="battery"          column="battery"            />
        <result property="status"           column="status"             />
        <result property="area"             column="area"               />
        <result property="currentMode"      column="current_mode"       />
        <result property="delFlag"          column="del_flag"           />
        <result property="createBy"         column="create_by"          />
        <result property="createTime"       column="created_at"         />
        <result property="updateBy"         column="update_by"          />
        <result property="updateTime"       column="updated_at"         />
        <result property="tenantId"         column="tenant_id"          />
    </resultMap>

    <sql id="selectScheduleVo">
        select
        schedule_id,
        schedule_name,
        mode_id,
        mode_name,
        execute_time,
        repeat_type,
        start_date,
        start_time,
        duration,
        status,
        last_execute_time,
        last_execute_status,
        del_flag,
        create_by,
        create_time,
        update_by,
        update_time,
        tenant_id
        from sys_mode_schedule
    </sql>

    <!-- 查询排程列表 - 使用 sysModeSchedule. 前缀 -->
    <select id="selectSysModeScheduleList" parameterType="com.ruoyi.mode.domain.SysModeSchedule" resultMap="SysModeScheduleResult">
        <include refid="selectScheduleVo"/>
        <where>
            AND tenant_id = #{sysModeSchedule.tenantId}
            <if test="sysModeSchedule.scheduleName != null and sysModeSchedule.scheduleName != ''">
                AND schedule_name like concat('%', #{sysModeSchedule.scheduleName}, '%')
            </if>
            <if test="sysModeSchedule.modeId != null">
                AND mode_id = #{sysModeSchedule.modeId}
            </if>
            <if test="sysModeSchedule.status != null and sysModeSchedule.status != ''">
                AND status = #{sysModeSchedule.status}
            </if>
            AND del_flag = '0'
        </where>
        order by create_time desc
    </select>

    <!-- 根据ID查询排程 - 使用 sysModeSchedule. 前缀 -->
    <select id="selectSysModeScheduleById" parameterType="com.ruoyi.mode.domain.SysModeSchedule" resultMap="SysModeScheduleResult">
        <include refid="selectScheduleVo"/>
        where schedule_id = #{sysModeSchedule.scheduleId}
        and tenant_id = #{sysModeSchedule.tenantId}
        and del_flag = '0'
    </select>

    <!-- 查询排程关联的机器人 -->
    <select id="selectRobotsByScheduleId" resultMap="SysRobotResult">
        select
        r.id,
        r.name,
        r.code,
        r.group_id,
        r.battery,
        r.status,
        r.area,
        r.current_mode,
        r.del_flag,
        r.create_by,
        r.created_at as create_time,
        r.update_by,
        r.updated_at as update_time
        from robots r
        inner join sys_schedule_robot sr on r.id = sr.robot_id
        where sr.schedule_id = #{scheduleId}
        and sr.tenant_id = #{tenantId}
        and r.del_flag = '0'
        order by r.id
    </select>

    <!-- 新增排程 -->
    <insert id="insertSysModeSchedule" parameterType="com.ruoyi.mode.domain.SysModeSchedule" useGeneratedKeys="true" keyProperty="scheduleId">
        insert into sys_mode_schedule(
        <if test="scheduleName != null and scheduleName != ''">schedule_name,</if>
        <if test="modeId != null">mode_id,</if>
        <if test="modeName != null and modeName != ''">mode_name,</if>
        <if test="executeTime != null and executeTime != ''">execute_time,</if>
        <if test="repeatType != null and repeatType != ''">repeat_type,</if>
        <if test="startDate != null">start_date,</if>
        <if test="startTime != null and startTime != ''">start_time,</if>
        <if test="duration != null">duration,</if>
        <if test="status != null and status != ''">status,</if>
        <if test="createBy != null and createBy != ''">create_by,</if>
        tenant_id, create_time
        ) values (
        <if test="scheduleName != null and scheduleName != ''">#{scheduleName},</if>
        <if test="modeId != null">#{modeId},</if>
        <if test="modeName != null and modeName != ''">#{modeName},</if>
        <if test="executeTime != null and executeTime != ''">#{executeTime},</if>
        <if test="repeatType != null and repeatType != ''">#{repeatType},</if>
        <if test="startDate != null">#{startDate},</if>
        <if test="startTime != null and startTime != ''">#{startTime},</if>
        <if test="duration != null">#{duration},</if>
        <if test="status != null and status != ''">#{status},</if>
        <if test="createBy != null and createBy != ''">#{createBy},</if>
        #{tenantId}, sysdate()
        )
    </insert>

    <!-- 修改排程 -->
    <update id="updateSysModeSchedule" parameterType="com.ruoyi.mode.domain.SysModeSchedule">
        update sys_mode_schedule
        <set>
            <if test="scheduleName != null and scheduleName != ''">schedule_name = #{scheduleName},</if>
            <if test="modeId != null">mode_id = #{modeId},</if>
            <if test="modeName != null and modeName != ''">mode_name = #{modeName},</if>
            <if test="executeTime != null and executeTime != ''">execute_time = #{executeTime},</if>
            <if test="repeatType != null and repeatType != ''">repeat_type = #{repeatType},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="startTime != null and startTime != ''">start_time = #{startTime},</if>
            <if test="duration != null">duration = #{duration},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="lastExecuteTime != null">last_execute_time = #{lastExecuteTime},</if>
            <if test="lastExecuteStatus != null and lastExecuteStatus != ''">last_execute_status = #{lastExecuteStatus},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where schedule_id = #{scheduleId}
    </update>

    <!-- 更新排程状态 -->
    <update id="updateScheduleStatus">
        update sys_mode_schedule
        set status = #{status}
        where schedule_id = #{scheduleId}
    </update>

    <!-- 逻辑删除排程（单个） -->
    <update id="deleteSysModeScheduleById" parameterType="Long">
        update sys_mode_schedule
        set del_flag = '2'
        where schedule_id = #{scheduleId}
    </update>

    <!-- 逻辑删除排程（批量） -->
    <update id="deleteSysModeScheduleByIds" parameterType="String">
        update sys_mode_schedule
        set del_flag = '2'
        where schedule_id in
        <foreach item="scheduleId" collection="array" open="(" separator="," close=")">
            #{scheduleId}
        </foreach>
    </update>

    <!-- 批量插入排程机器人关联 -->
    <insert id="insertScheduleRobots">
        INSERT INTO sys_schedule_robot (schedule_id, robot_id, robot_name, tenant_id)
        SELECT #{scheduleId}, id, name, #{tenantId}
        FROM robots
        WHERE id IN
        <foreach item="robotId" collection="robotIds" open="(" separator="," close=")">
            #{robotId}
        </foreach>
        AND del_flag = '0'
    </insert>

    <!-- 删除排程机器人关联 -->
    <delete id="deleteScheduleRobots" parameterType="Long">
        delete from sys_schedule_robot
        where schedule_id = #{scheduleId}
    </delete>

    <!-- 批量删除排程机器人关联 -->
    <delete id="deleteScheduleRobotsByScheduleIds" parameterType="Long">
        delete from sys_schedule_robot
        where schedule_id in
        <foreach item="scheduleId" collection="array" open="(" separator="," close=")">
            #{scheduleId}
        </foreach>
    </delete>

</mapper>