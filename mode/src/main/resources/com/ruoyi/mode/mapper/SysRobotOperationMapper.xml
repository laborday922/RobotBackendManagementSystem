<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mode.mapper.SysRobotOperationMapper">

    <resultMap type="com.ruoyi.mode.domain.SysRobotOperation" id="SysRobotOperationResult">
        <id     property="operationId"       column="operation_id"       />
        <result property="robotId"           column="robot_id"           />
        <result property="robotName"         column="robot_name"         />
        <result property="operationType"     column="operation_type"     />
        <result property="operationResult"   column="operation_result"   />
        <result property="operationTime"     column="operation_time"     />
        <result property="operator"          column="operator"           />
        <result property="remark"            column="remark"             />
        <result property="tenantId"          column="tenant_id"          />
    </resultMap>

    <sql id="selectOperationVo">
        select operation_id, robot_id, robot_name, operation_type,
        operation_result, operation_time, operator, remark, tenant_id
        from sys_robot_operation
    </sql>

    <select id="selectSysRobotOperationList" parameterType="com.ruoyi.mode.domain.SysRobotOperation" resultMap="SysRobotOperationResult">
        <include refid="selectOperationVo"/>
        <where>
            AND tenant_id = #{tenantId}
            <if test="robotId != null">
                AND robot_id = #{robotId}
            </if>
            <if test="operationType != null and operationType != ''">
                AND operation_type = #{operationType}
            </if>
            <if test="operationResult != null and operationResult != ''">
                AND operation_result = #{operationResult}
            </if>
        </where>
        order by operation_time desc
    </select>

    <select id="selectSysRobotOperationById" parameterType="com.ruoyi.mode.domain.SysRobotOperation" resultMap="SysRobotOperationResult">
        <include refid="selectOperationVo"/>
        where operation_id = #{operationId} and tenant_id = #{tenantId}
    </select>

    <insert id="insertSysRobotOperation" parameterType="com.ruoyi.mode.domain.SysRobotOperation" useGeneratedKeys="true" keyProperty="operationId">
        insert into sys_robot_operation(
        <if test="robotId != null">robot_id,</if>
        <if test="robotName != null and robotName != ''">robot_name,</if>
        <if test="operationType != null and operationType != ''">operation_type,</if>
        <if test="operationResult != null and operationResult != ''">operation_result,</if>
        <if test="operationTime != null">operation_time,</if>
        <if test="operator != null and operator != ''">operator,</if>
        <if test="remark != null and remark != ''">remark,</if>
        tenant_id, create_time
        )values(
        <if test="robotId != null">#{robotId},</if>
        <if test="robotName != null and robotName != ''">#{robotName},</if>
        <if test="operationType != null and operationType != ''">#{operationType},</if>
        <if test="operationResult != null and operationResult != ''">#{operationResult},</if>
        <if test="operationTime != null">#{operationTime},</if>
        <if test="operator != null and operator != ''">#{operator},</if>
        <if test="remark != null and remark != ''">#{remark},</if>
        #{tenantId}, sysdate()
        )
    </insert>

    <delete id="deleteSysRobotOperationById" parameterType="Long">
        delete from sys_robot_operation where operation_id = #{operationId}
    </delete>

    <delete id="deleteSysRobotOperationByIds" parameterType="String">
        delete from sys_robot_operation where operation_id in
        <foreach item="operationId" collection="array" open="(" separator="," close=")">
            #{operationId}
        </foreach>
    </delete>

</mapper>