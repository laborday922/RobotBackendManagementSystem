<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ruoyi.data.ai.mapper.ReportContentMapper">

    <insert id="insertContent" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO data_report_content (
            report_id, content, summary, highlights, created_at
        ) VALUES (
                     #{reportId}, #{content}, #{summary}, #{highlights}, NOW()
                 )
    </insert>

    <select id="selectContentByReportId" resultType="com.ruoyi.data.ai.mapper.po.ReportContentPo">
        SELECT * FROM data_report_content WHERE report_id = #{reportId}
    </select>

</mapper>